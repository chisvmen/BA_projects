        <mxCell id="FQdFBHBTgsBbnK0Ybh1a-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;img src=&quot;data:image/png;base64,&quot; alt=&quot;&quot;&gt;" vertex="1">
