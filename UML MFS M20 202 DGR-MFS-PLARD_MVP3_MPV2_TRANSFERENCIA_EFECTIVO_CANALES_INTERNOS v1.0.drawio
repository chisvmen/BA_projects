        <mxCell id="uTxw8-D9npwiXjfJBiML-3" parent="1" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;edgeStyle&quot;:&quot;elbowEdgeStyle&quot;,&quot;elbow&quot;:&quot;vertical&quot;,&quot;curved&quot;:0,&quot;rounded&quot;:0};align=center;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;font-weight: 700;&quot;&gt;&lt;div&gt;&amp;lt;&amp;lt;Altair 390&amp;gt;&amp;gt;&lt;br&gt;&lt;/div&gt;CAPTACION&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="7288" width="175.43" x="15679" y="-1989" as="geometry" />
        </mxCell>
        <mxCell id="YztjXETtfEHv8K0vt9EI-1" parent="1" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;edgeStyle&quot;:&quot;elbowEdgeStyle&quot;,&quot;elbow&quot;:&quot;vertical&quot;,&quot;curved&quot;:0,&quot;rounded&quot;:0};align=center;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;font-weight: 400;&quot;&gt;&lt;div&gt;&lt;b&gt;&amp;lt;Queue&amp;gt;&amp;gt;&amp;nbsp;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;b&gt;MQ 390&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="7301" width="160" x="15214" y="-1989" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeColor=default;" value="&lt;div&gt;&lt;div&gt;&lt;b&gt;Funcionalidad:&lt;/b&gt;&amp;nbsp;Transacción MPV2 - Realizar la gestión de efectivo entre cuentas para realizar el pago de una tarjeta de crédito (TDC).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Alcance&lt;/b&gt;: MPV-Full Credit&amp;nbsp; -&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Esta transacción permite al cliente realizar la transferencia de efectivo para realizar el pago de la tarjeta de credito a traves del canal.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;Reglas de negocio&lt;/b&gt;.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;ul data-start=&quot;303&quot; data-end=&quot;493&quot;&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aplica únicamente para Tarjetas de Crédito (TDC).&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El cliente del Banco Santander debe contar con una tarjeta de crédito activa.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: initial;&quot;&gt;Precondiciones:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li data-section-id=&quot;wewzqy&quot; data-start=&quot;776&quot; data-end=&quot;830&quot;&gt;El cliente debe contar con una tarjeta de crédito.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1ptqf3d&quot; data-start=&quot;831&quot; data-end=&quot;884&quot;&gt;El cliente debe contar con una tarjeta de débito.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;h9g0ni&quot; data-start=&quot;885&quot; data-end=&quot;938&quot;&gt;La tarjeta de débito debe estar vigente y activa.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1rgal8d&quot; data-start=&quot;939&quot; data-end=&quot;993&quot;&gt;La tarjeta de crédito debe estar vigente y activa.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1htyjoa&quot; data-start=&quot;994&quot; data-end=&quot;1050&quot;&gt;La tarjeta de débito debe estar asignada al cliente.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1nkm2tl&quot; data-start=&quot;1051&quot; data-end=&quot;1108&quot;&gt;La tarjeta de crédito debe estar asignada al cliente.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;r71jpl&quot; data-start=&quot;1109&quot; data-end=&quot;1175&quot;&gt;La tarjeta de débito debe estar vinculada a una cuenta activa.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1u3wyu2&quot; data-start=&quot;1176&quot; data-end=&quot;1243&quot;&gt;La tarjeta de crédito debe estar vinculada a una cuenta activa.&lt;/li&gt;&lt;/ul&gt;&lt;b style=&quot;background-color: initial; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Post-Condiciones:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: initial; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;ul type=&quot;disc&quot; style=&quot;margin-top: 0cm;&quot;&gt;&lt;li data-section-id=&quot;pb8c89&quot; data-start=&quot;1273&quot; data-end=&quot;1385&quot;&gt;El canal muestra al cliente la información resultante de la operación realizada sobre su tarjeta de crédito.&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;rrh3su&quot; data-start=&quot;1386&quot; data-end=&quot;1523&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;El ejecutivo (en su caso) muestra al cliente la información correspondiente al resumen o extracto actualizado de su tarjeta de crédito.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="519" width="769" x="4971" y="-2290" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Funcionalidad" vertex="1">
          <mxGeometry height="40" width="769" x="4971" y="-2330" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;align=center;fillColor=#bac8d3;strokeColor=#23445d;shadow=0;" value="Escenarios" vertex="1">
          <mxGeometry height="42" width="769" x="4971" y="-1752" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=#d6b656;fillColor=#fff2cc;" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;Escenario 1: Pago de Tarjeta de Crédito en efectivo desde Cajero Automático (ATM)&lt;/font&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Esta transacción permite al cliente realizar el pago en efectivo de una tarjeta de crédito a través del canal ATM.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;La operativa se lleva a cabo a partir de la información contenida en los datos de entrada obligatorios de la solicitud, ingresados a través del canal ATM. Posteriormente, se ejecuta la operación correspondiente del API PLARD de pagos TBD mediante la Capa de Integración.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Consideraciones:&lt;/b&gt;&lt;/span&gt;&lt;ul&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;La plataforma PLARD, en conjunto con la Capa de Integración, procesa y gestiona la solicitud de pago.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;La Capa de Integración procesa el resultado de la operación y notifica al sistema Lynx para fines de monitoreo de fraude.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El canal presenta al cliente la información del resultado de la operación, incluyendo la respuesta del pago de la tarjeta de crédito.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;; realiza el ajuste de los saldos, realiza informe por fraude y/o permite la anulacion del pago de la tarjeta.&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br style=&quot;white-space: normal;&quot;&gt;&lt;/div&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="301" width="769" x="4971" y="-1710" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-5" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=#d6b656;fillColor=#fff2cc;" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;Escenario 2:&amp;nbsp;&lt;/font&gt;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Pago de Tarjeta de Crédito con cargo a cuenta de débito&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Esta transacción permite al cliente realizar el pago de una tarjeta de crédito con cargo a una cuenta de débito.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;La operativa se lleva a cabo a partir de la información contenida en los datos de entrada obligatorios de la solicitud, ingresada a través del canal. Posteriormente, se realiza el cargo a la cuenta de débito correspondiente mediante la API de Captación de Cargos (TBD), a través de la Capa de Integración. Una vez efectuado el cargo, se ejecuta la operación correspondiente del API PLARD de pagos (TBD) mediante la misma Capa de Integración.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Consideraciones:&lt;/b&gt;&lt;/span&gt;&lt;ul&gt;&lt;li style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;La plataforma de Captación, en conjunto con la Capa de Integración, procesa el cargo a la cuenta de débito del cliente.&lt;br/&gt;La plataforma PLARD, en conjunto con la Capa de Integración, procesa y ejecuta el pago de la tarjeta de crédito del cliente.&lt;br/&gt;En caso de que la operación no pueda ser procesada exitosamente, la Capa de Integración ejecuta la API de anulación (TBD) para cancelar el movimiento en la tarjeta y permitir la reversión de la operación.&lt;br/&gt;La Capa de Integración procesa el resultado de la operación y notifica al sistema Lynx (API TBD LYNX) para fines de monitoreo de fraude.&lt;br/&gt;El canal presenta al cliente la información del resultado de la operación, incluyendo la respuesta del pago de la tarjeta de crédito.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="301" width="769" x="4971" y="-1402" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;fontSize=14;fontStyle=1;verticalAlign=top;container=0;" value="Transacción Altair 390: MPV2 (PAMPA)" vertex="1">
          <mxGeometry height="42" width="1182" x="5799" y="-2282" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;align=left;strokeColor=#666666;fillColor=#f5f5f5;fontColor=#333333;" value="&lt;span style=&quot;font-size: 12px;&quot;&gt;Formato = MPM0608:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 12px; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ENTRADA CANALES INTERNOS&lt;/span&gt;&lt;span style=&quot;font-size: 12px; white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&#x9;&#x9;&lt;/span&gt; &lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;font-size: 12px; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Tipo (E/S/A) = Entrada&lt;/span&gt;" vertex="1">
          <mxGeometry height="178" width="1182" x="5799" y="-2240" as="geometry" />
        </mxCell>
        <mxCell id="JrR9tKulK5KLRj4bW-tz-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bac8d3;strokeColor=#23445d;fontSize=14;fontStyle=1;verticalAlign=top;container=0;" value="Mapeo" vertex="1">
