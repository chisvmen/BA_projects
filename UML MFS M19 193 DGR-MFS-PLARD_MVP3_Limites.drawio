t; style=&quot;height: 20.25pt;&quot;&gt;&lt;td height=&quot;27&quot; class=&quot;xl57&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap; height: 20.25pt;&quot;&gt;08&lt;/td&gt;&lt;td class=&quot;xl57&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;LIMDEBD&lt;/td&gt;&lt;td class=&quot;xl57&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;LIMITE DEBITO DIA&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/td&gt;&lt;td class=&quot;xl59&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap; text-align: center;&quot;&gt;17.2&lt;/td&gt;&lt;td class=&quot;xl57&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;Numérico con signo&lt;/td&gt;&lt;td class=&quot;xl57&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;Salida&lt;/td&gt;&lt;td colspan=&quot;3&quot; width=&quot;546&quot; height=&quot;27&quot; class=&quot;xl2764&quot; style=&quot;padding-top: 1px; padding-