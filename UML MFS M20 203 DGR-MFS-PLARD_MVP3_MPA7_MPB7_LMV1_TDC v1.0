t;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema consulta los datos económicos de la tarjeta, como los límites diarios y mensuales de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo modifica los datos económicos de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema actualiza los datos económicos de la tarjeta en el sistema.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema confirma al Ejecutivo que los datos económicos de la tarjeta han sido modificados y actualizados.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
