          <mxGeometry height="40" width="732" x="4138" y="-2338" as="geometry" />
        </mxCell>
        <mxCell id="CNWZ6g8ySVLg3BFARsDs-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;align=center;fillColor=#bac8d3;strokeColor=#23445d;" value="Escenarios" vertex="1">
          <mxGeometry height="42" width="732" x="4138" y="-1861.39" as="geometry" />
        </mxCell>
        <mxCell id="CNWZ6g8ySVLg3BFARsDs-4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=default;fontColor=light-dark(#000000,#FFFFFF);" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Escenario 1:&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;&lt;font&gt;&lt;span style=&quot;font-size: 13px; white-space-collapse: preserve;&quot;&gt;&lt;b&gt;Modificación de datos económicos de la tarjeta&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo Santander solicita la modificación de los datos económicos de la tarjeta del cliente.&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Consideraciones:&lt;/b&gt;&lt;/span&gt;&lt;ul&gt;&lt;/ul&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;&lt;ol style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo accede al canal FDMP.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo selecciona la opción “Mantenimiento de Tarjetas”.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo selecciona la opción “Límites de tarjeta por moneda”.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo selecciona el botón “Modificar”.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;La plataforma PLARD, en conjunto con la Capa de Integración, realiza la consulta de los datos económicos de la tarjeta, como los límites diarios y mensuales.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El ejecutivo solicita la modificación de los datos económicos de la tarjeta.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;La plataforma PLARD, en conjunto con la Capa de Integración, actualiza los datos económicos de la tarjeta en el sistema.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;El canal confirma al ejecutivo que los datos económicos de la tarjeta del cliente han sido modificados y actualizados correctamente.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="732" x="4138" y="-1819.39" as="geometry" />
        </mxCell>
