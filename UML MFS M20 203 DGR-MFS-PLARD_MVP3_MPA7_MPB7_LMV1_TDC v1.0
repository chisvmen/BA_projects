        <mxCell id="dsGI18B7b8BIxwh5u17H-143" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=default;" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Escenario 1:&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;span style=&quot;font-weight: bold; font-size: 13px;&quot;&gt;Modificación de datos económicos de la tarjeta&lt;br&gt;&lt;br&gt;&lt;/span&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo modifica datos económicos de la tarjeta del Cliente.&lt;br&gt;&lt;br&gt;Consideraciones:&lt;br&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo accede al canal FDMP.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona la opción &quot;Mantenimiento de Tarjetas&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona la opción &quot;Limites de tarjeta por moneda&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona el botón &quot;Modificar&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema consulta los datos económicos de la tarjeta, como los límites diarios y mensuales de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo modifica los datos económicos de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema actualiza los datos económicos de la tarjeta en el sistema.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema confirma al Ejecutivo que los datos económicos de la tarjeta han sido modificados y actualizados.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="287" width="521" x="50" y="565" as="geometry" />
        </mxCell>
