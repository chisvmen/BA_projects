        <mxCell id="evzYAYAgrgpNHfuNtCvy-112" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=default;" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Escenario 1:&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;span style=&quot;font-weight: bold; font-size: 13px;&quot;&gt;Consulta Limites de una Tarjeta &lt;br&gt;&lt;br&gt;&lt;/span&gt;&lt;font style=&quot;&quot;&gt;El Ejecutivo consulta los límites de una tarjeta de débito.&lt;br&gt;&lt;br&gt;Consideraciones:&lt;br&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font style=&quot;&quot;&gt;El Ejecutivo accede al canal FDMP.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font style=&quot;&quot;&gt;El Ejecutivo selecciona la opción &quot;Mantenimiento de Tarjetas&quot;, después la opción &quot;Limites de tarjeta por moneda&quot; y enseguida el botón &quot;Detalles&quot;, que es la consulta de limites de una tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font style=&quot;&quot;&gt;El Sistema busca los límites de la tarjeta del cliente.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font style=&quot;&quot;&gt;El Sistema muestra los límites diarios y mensuales de la tarjeta del cliente.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="197" width="521" x="30" y="583" as="geometry" />
        </mxCell>
