        <mxCell id="FrK47Qw90K8gpvqheAlr-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillStyle=hatch;" value="" vertex="1">
          <mxGeometry height="1367" width="1520" x="916" y="413" as="geometry" />
