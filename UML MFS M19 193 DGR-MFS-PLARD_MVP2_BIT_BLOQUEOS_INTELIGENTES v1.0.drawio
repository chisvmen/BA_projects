quot;xl761&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;cardOperations[].operationCode&lt;/td&gt;&lt;td class=&quot;xl762&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 11pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;&lt;/td&gt;&lt;td class=&quot;xl761&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;String&lt;/td&gt;&lt;td class=&quot;xl761&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;Bloqueo aplicado&lt;/td&gt;&lt;td class=&quot;xl761&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;requerido&lt;/td&gt;&lt;td class=&quot;xl761&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;, sans-serif; vertical-align: middle; border: 0.5pt solid black; white-space: nowrap;&quot;&gt;&lt;/td&gt;&lt;td width=&quot;64&quot; class=&quot;xl763&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;; vertical-align: top; border: 0.5pt solid black; width: 48pt;&quot;&gt;&lt;/td&gt;&lt;td width=&quot;418&quot; class=&quot;xl763&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: &amp;quot;Aptos Narrow&amp;quot;; vertical-align: top; border: 0.5pt solid black; width: 314pt;&quot;&gt;Si (lock_id == &quot;general&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;GENERAL&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;internet&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;INTERNET&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;internacional&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;INTERNATIONAL&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;pos&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;POS&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;atm&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;ATM&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;moto&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;MOTO&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;contactless&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;CONTACTLESS&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;br&gt;Si (lock_id == &quot;walletcontactless&quot; &amp;amp;&amp;amp; existe(cardOperations[].operationCode = &quot;WALLETCONTACTLESS&quot;))&amp;nbsp; entonces return enabled = true sino return enabled = false&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
