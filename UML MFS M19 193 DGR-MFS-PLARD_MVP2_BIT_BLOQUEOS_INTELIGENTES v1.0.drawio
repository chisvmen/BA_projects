style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border-top: 0.5pt solid rgb(217, 217, 217); border-right: none; border-bottom: 0.5pt solid rgb(217, 217, 217); border-left: 0.5pt solid rgb(217, 217, 217); border-image: initial; text-wrap-mode: nowrap;&quot;&gt;Corresponde al pan&lt;/td&gt;&lt;/tr&gt;&lt;tr height=&quot;31&quot; style=&quot;height: 23.25pt;&quot;&gt;&lt;td height=&quot;31&quot; class=&quot;xl774&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap; text-align: center; height: 23.25pt;&quot;&gt;2&lt;/td&gt;&lt;td class=&quot;xl775&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;product_type&lt;/td&gt;&lt;td class=&quot;xl775&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;Product type&lt;/td&gt;&lt;td class=&quot;xl775&quot; align=&quot;right&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;22&lt;/td&gt;&lt;td class=&quot;xl775&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap;&quot;&gt;Alfanumerico&lt;/td&gt;&lt;td class=&quot;xl776&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border-top: 0.5pt solid rgb(191, 191, 191); border-right: none; border-bottom: 0.5pt solid rgb(191, 191, 191); border-left: 0.5pt solid rgb(191, 191, 191); border-image: initial; text-wrap-mode: nowrap;&quot;&gt;Requerido&lt;/td&gt;&lt;td class=&quot;xl777&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; font-size: 8pt; font-family: Calibri, sans-serif; vertical-align: middle; border-top: 0.5pt solid rgb(217, 217, 217); border-right: none; border-bottom: 0.5pt solid rgb(217, 217, 217); border-left: 0.5pt solid rgb(217, 217, 217); border-image: initial; text-wrap-mode: nowrap;&quot;&gt;&quot;cards&quot;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
