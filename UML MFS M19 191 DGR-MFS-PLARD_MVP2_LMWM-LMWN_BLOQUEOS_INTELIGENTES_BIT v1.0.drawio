        <mxCell id="_wseQT55jjj6OUT0LNBo-99" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;div style=&quot;font-size: 11px; font-weight: bold;&quot;&gt;API BaaS&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;PUT&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 11px;&quot;&gt;&lt;b&gt;/cards/v2/cards/{card-key}/temporal-locks&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Entrada:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Headers&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Authorization = Token de autorización para acceder a los servicios de la API.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Accept = Parámetro de encabezado donde el consumidor define el formato de datos de la solicitud.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Content-Type = Parámetro de encabezado que indica el formato de datos del servidor en la respuesta.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-ibm-client-id&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;= Identificador de la aplicación del consumidor (solo IBM).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-global-transaction-id = Encabezado de ID de transacción global&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-santander-client-id = Encabezado de ID de cliente&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-Device-Fongerprint = Información de la huella digital registrada en el dispositivo.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-Geolocation = Geolocalización&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-B3-TraceId = Información de identificador único de traza a través del sistema.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-B3-SpanId = Información de identificador único de posición actual en árbol de rastreo.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Path:&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;card-key =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;Identificador único de tarjeta. Compuesto&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;de PAN, PRODUCT y SUBPROD&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;/bit/{product_type}/{PAN}/locks =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;Habilitar bloqueo inteligente&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;/bit/{product_type}/{PAN}/locks/deactivate =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Deshabilitar bloqueo inteligente&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;CardEnrollInfo/CardNum [PAN-&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;LMWN&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;] =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;BLOQUEO TEMPORAL DE TARJETAS&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Body&lt;/b&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;body =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;Indicador booleano de estado actual de bloqueo inteligente. true/false.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;&lt;div&gt;body.international =&amp;nbsp;Indicador booleano de estado actual de bloqueo inteligente. true/false.&lt;/div&gt;&lt;div&gt;body.pos =&amp;nbsp;Indicador booleano de estado actual de bloqueo inteligente. true/false.&lt;/div&gt;&lt;div&gt;body.internet =&amp;nbsp;Indicador booleano de estado actual de bloqueo inteligente. true/false.&lt;/div&gt;&lt;div&gt;body.atm =&amp;nbsp;Indicador booleano de estado actual de bloqueo inteligente. true/false.&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Complementos de entrada&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;que deberán ser informados en los servicios AaaS o DDFs para poder ser ejecutados:&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;ProductType =&amp;nbsp;Tipo de producto. CARDS&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;ProductType =&amp;nbsp;Tipo de producto. CARDS&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 9px;&quot;&gt;MsgRqHdr/ChannelId = [&lt;b&gt;CANOPER-LMWN&lt;/b&gt;] =&amp;nbsp;Canal Operativo&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;&lt;b&gt;Salida para activar o desactivar bloqueo inteligente&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;:&lt;/b&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;data.display_card_number = Número de la tarjeta ofuscada. Ejemplo *1234&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data.locks.international = Estatus después del bloqueo/desbloqueo inteligente &quot;international-international&quot;.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data.locks.pos = Estatus después del bloqueo/desbloqueo inteligente &quot;pos-pos&quot;.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data.locks.internet = Estatus después del bloqueo/desbloqueo inteligente &quot;internet-internet&quot;.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data.locks = Estatus después del bloqueo/desbloqueo inteligente &quot;atm-atm&quot;.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;notifications[].level = En caso de un error o notificación en la operación, indicará la severidad.&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;notifications[].code = En caso de un error o notificación en la operación, indicará el código relacionado.&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;notifications[].message = En caso de un error o notificación en la operación, indicará la descripción relacionada.&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;notifications[].timestamp = Fecha en que se ejecutó la operación en microservicio.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="540" width="580" x="1314" y="190" as="geometry" />
        </mxCell>
        <mxCell id="_wseQT55jjj6OUT0LNBo-100" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;As Is&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;Proceso:&lt;/u&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;1.- Cliente accede a la SM (Posición Global)&lt;/div&gt;&lt;div&gt;2.-&amp;nbsp; SM obtiene el resumen de tarjetas del cliente.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;GET /v3/cards?expands=PRODUCT,CARD_NUMBER_ENCRYPTED&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3.- Cliente ingresa al detalle de la tarjeta&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4.- Cliente da tap en la opción Bloqueos selectivos&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5.- SM o&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;btiene lista de bloqueos de tarjeta.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;GET&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;/cards/{card-key}/locks&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;6.- Cliente habilita o deshabilita bloqueos selectivos&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;7.- SM b&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;loquea o desbloquea una tarjeta para permitir o denegar compras temporalmente en canales específicos.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;PUT&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;/cards/{card-key}/selective-locks&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="199" width="617" x="84" y="530" as="geometry" />
        </mxCell>
      </root>
