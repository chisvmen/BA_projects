        <mxCell id="35MpFgY_OFhV77X8WtxH-117" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;font-size: medium; text-align: start;&quot; data-ccp-timestamp=&quot;1759428714567&quot;&gt;&lt;div data-ccp-timestamp=&quot;1759429946467&quot;&gt;&lt;div data-ccp-timestamp=&quot;1759429959450&quot;&gt;&lt;div data-ccp-timestamp=&quot;1759429978956&quot;&gt;&lt;div data-ccp-timestamp=&quot;1759429993657&quot;&gt;&lt;div data-ccp-timestamp=&quot;1762201028966&quot;&gt;&lt;div data-ccp-timestamp=&quot;1770788103361&quot;&gt;&lt;table width=&quot;1096&quot; style=&quot;border-collapse: collapse; width: 822pt;&quot;&gt;&lt;colgroup&gt;&lt;col width=&quot;14&quot; style=&quot;width: 11pt;&quot;&gt;&lt;col width=&quot;64&quot; style=&quot;width: 48pt;&quot;&gt;&lt;col width=&quot;182&quot; style=&quot;width: 137pt;&quot;&gt;&lt;col width=&quot;64&quot; style=&quot;width: 48pt;&quot;&gt;&lt;col width=&quot;131&quot; style=&quot;width: 98pt;&quot;&gt;&lt;col width=&quot;76&quot; style=&quot;width: 57pt;&quot;&gt;&lt;col width=&quot;370&quot; style=&quot;width: 278pt;&quot;&gt;&lt;col width=&quot;195&quot; style=&quot;width: 146pt;&quot;&gt;&lt;/colgroup&gt;&lt;tbody&gt;&lt;tr height=&quot;20&quot; style=&quot;height: 15pt;&quot;&gt;&lt;td width=&quot;14&quot; height=&quot;20&quot; class=&quot;xl340&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-weight: 700; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap; background: rgb(242, 206, 239); width: 11pt; height: 15pt;&quot;&gt;#&lt;/td&gt;&lt;td width=&quot;64&quot; class=&quot;xl340&quot; style=&quot;padding-top: 1px; padding-right: 1px; padding-left: 1px; color: rgb(0, 32, 96); font-size: 8pt; font-weight: 700; font-family: Calibri, sans-serif; vertical-align: middle; border: 0.5pt solid rgb(191, 191, 191); text-wrap-mode: nowrap; background: rgb(242, 206, 23