        <mxCell id="_wseQT55jjj6OUT0LNBo-45" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;div style=&quot;font-size: 11px;&quot;&gt;API BaaS&lt;/div&gt;&lt;div style=&quot;font-size: 11px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;GET&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;/cards/{card-key}/locks&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Entrada:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Headers&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Authorization = Token de autorización para acceder a los servicios de la API.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Accept = Parámetro de encabezado donde el consumidor define el formato de datos de la solicitud.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Content-Type = Parámetro de encabezado que indica el formato de datos del servidor en la respuesta.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-ibm-client-id&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;= Identificador de la aplicación del consumidor (solo IBM).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-global-transaction-id = Encabezado de ID de transacción global&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;x-santander-client-id = Encabezado de ID de cliente&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-Device-Fongerprint = Información de la huella digital registrada en el dispositivo.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-Geolocation = Geolocalización&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-B3-TraceId = Información de identificador único de traza a través del sistema.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;X-B3-SpanId = Información de identificador único de posición actual en árbol de rastreo.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Path:&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;card-key =&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;Identificador único de tarjeta. Compuesto&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;de PAN, PRODUCT y SUBPROD&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Complementos de entrada&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;que deberán ser informados en los servicios AaaS o DDFs para poder ser ejecutados:&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;ProductType =&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; font-size: 10px;&quot;&gt;Tipo de producto. CARDS&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Salida:&lt;/b&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div style=&quot;font-size: 10px;&quot;&gt;&lt;div&gt;data.international = Estatus de bloqueo para compras generadas con registro fuera del territorio mexicano. Puede ser true o false.&lt;/div&gt;&lt;div&gt;data.pos = Estatus de bloqueo para las compras realizadas por medio de la terminal. Puede ser true o false.&lt;/div&gt;&lt;div&gt;data.internet = Estatus de bloqueo para las compras en línea o vía telefónica. Puede ser true o false.&lt;/div&gt;&lt;div&gt;data.atm = Estatus de bloqueo para los retiros de efectivo en cualquier cajero automático. Puede ser true o false.&lt;/div&gt;&lt;div&gt;notifications[].level = Error o notificación en la operación se mapeará la salida Transacción status.additionalStatus.severity&lt;/div&gt;&lt;div&gt;notifications[].code = Error o notificación en la operación se mapeará la salida Transacción status.additionalStatus.statusCode&lt;/div&gt;&lt;div&gt;notifications[].message = Error o notificación en la operación se mapeará Transacción status.additionalStatus.statusDesc&lt;/div&gt;&lt;div&gt;notifications[].timestamp = Timestamp de la operación, el microservicio será el encargado de proveer este timestamp.&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="400" width="580" x="84" y="40" as="geometry" />
        </mxCell>
        <mxCell id="_wseQT55jjj6OUT0LNBo-46" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;div style=&quot;text-align: center;&quot;&gt;API BaaS&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;GET /v3/cards?expands=PRODUCT,CARD_NUMBER_ENCRYPTED&lt;/div&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Entrada:&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Headers&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Authorization = Token de autorización para acceder a los servicios de la API.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Accept = Parámetro de encabezado donde el consumidor define el formato de datos de la solicitud.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Content-Type = Parámetro de encabezado que indica el formato de datos del servidor en la respuesta.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;x-ibm-client-id&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;= Identificador de la aplicación del consumidor (solo IBM).&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;x-global-transaction-id = Encabezado de ID de transacción global&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;x-santander-client-id = Encabezado de ID de cliente&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;X-Device-Fongerprint = Información de la huella digital registrada en el dispositivo.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;X-Geolocation = Geolocalización&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;X-B3-TraceId = Información de identificador único de traza a través del sistema.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;X-B3-SpanId = Información de identificador único de posición actual en árbol de rastreo.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;public_key = Llave pública para los datos encriptados.&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Complementos de entrada&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;que deberán ser informados en los servicios AaaS o DDFs para poder ser ejecutados:&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;CardSel/PartyKeys/PartyId = [&lt;/span&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;IDENTCTL-&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;LMWT&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;]&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Número de cliente&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Salida:&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;div style=&quot;&quot;&gt;data[].key = [&lt;b&gt;PAN|PRODUCT|SUBPROD-LMWT&lt;/b&gt;]&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Identificador único de Tarjeta.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].display_number = [&lt;b&gt;PAN-LMWT&lt;/b&gt;]&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Número de tarjeta. Ejemplo: (*1234).&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].description = [&lt;b&gt;DESPROD-LMWT&lt;/b&gt;]&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Descripción producto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].expiration_date = [&lt;b&gt;FECCADU-LMWT&lt;/b&gt;] Fecha de vencimiento en formato MM/YY.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].relation_type = [&lt;b&gt;CALPART-LMWT&lt;/b&gt;] Calidad de participación.Los valores son: PRIMARY y ADDITIONAL&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].status = [&lt;b&gt;INDSITT-LMWT&lt;/b&gt;] Estatus de tarjeta.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].holder_name = [&lt;b&gt;NOMBENR-LMWT&lt;/b&gt;] Nombre en estampación.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].image_code = [&lt;b&gt;PRODUCT|SUBPROD|CODMAR|CONDEST-LMWT&lt;/b&gt;] Código de imagen.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].embossing_code = [&lt;b&gt;CONDEST-LMWT&lt;/b&gt;] Condición de estampación&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].issue_code = [&lt;b&gt;INDSITT-LMWT&lt;/b&gt;] Indicador de situación de tarjeta&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].type_code = [&lt;b&gt;INDTIPT-LMWT&lt;/b&gt;] Indicador de tipo de tarjeta&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].contract_id = [&lt;b&gt;CUENTA-LMWT&lt;/b&gt;] Contrato asociado&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].branch_id = [&lt;b&gt;CENTRO-LMWT&lt;/b&gt;] Código de sucursal&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].type = [&lt;b&gt;TECNOLO-LMWT&lt;/b&gt;] Indica el tipo de tarjetas a devolver.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].url = Path para el siguiente llamado dentro del flujo autodescriptivo de la API.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].key = [&lt;b&gt;PAN|PRODUCT|SUBPROD-LMWT&lt;/b&gt;] Identificador único de Tarjeta relacionada.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].relation_type = [&lt;b&gt;CALPART-LMWT&lt;/b&gt;] Calidad de participación (PRIMARY y ADDITIONAL)&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].type = [&lt;b&gt;TECNOLO-LMWT&lt;/b&gt;] Indica el tipo de tarjeta relacionada.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].status= [&lt;b&gt;INDSITT-LMWT&lt;/b&gt;] Estatus de tarjeta relacionada.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].image_code = [&lt;b&gt;PRODUCT|SUBPROD|CODMAR|CONDEST-LMWT&lt;/b&gt;] Refiere al código de imagen de tarjeta&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].related_cards[].url = Path para el siguiente llamado dentro del flujo autodescriptivo de la API.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].available_products[].key = Identificador único del producto de crédito. *NO IMPLEMENTADO&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].available_products[].name = El tipo del nuevo producto disponible&amp;nbsp; *NO IMPLEMENTADO&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].available_products[].image_code = Refiere al código de imagen PRODUCT|SUBPROD|CODMAR|CONDEST *NO IMPLEMENTADO&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].entitlements.key = Código de permiso sobre el producto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].entitlements.value = Descripción del permiso sobre el producto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;notifications[].level = En caso de un error o notificación en la operación, indicará la severidad.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;notifications[].code = En caso de un error o notificación en la operación, indicará el código relacionado.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;notifications[].message = En caso de un error o notificación en la operación, indicará la descripción relacionada.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;notifications[].timestamp = Fecha en que se ejecutó la operación en microservicio.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;paging.next_cursor_key = Cursor para la siguiente llamada del conjunto de registros recuperados.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Salida expands=PRODUCT&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;data[].product.code&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;= [&lt;b&gt;PRODUCT-LMWT&lt;/b&gt;] Código de producto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].product.name = [&lt;b&gt;DESPROD-LMWT&lt;/b&gt;] Descripción de producto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].product.subproduct_code = [&lt;b&gt;SUBPROD-LMWT&lt;/b&gt;] Código de subproducto.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].product.subproduct_name = [&lt;b&gt;CODMAR-LMWT&lt;/b&gt;] Marca de la tarjeta.&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Salida expands=CARD_NUMBER_ENCRYPTED&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;data[].card_number_encrypted = [&lt;b&gt;PAN-LMWT&lt;/b&gt;] Número de tarjeta encriptado.&lt;/div&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
