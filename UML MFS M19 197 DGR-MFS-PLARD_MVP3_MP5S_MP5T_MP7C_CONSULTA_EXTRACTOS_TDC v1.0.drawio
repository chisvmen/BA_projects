        <mxCell id="PuF2dmNS-M8CWl-lxtja-108" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;div&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); text-align: left; color: rgb(36, 36, 36);&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Componente&lt;br&gt;&lt;b&gt;PAMPA&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(36, 36, 36); text-align: left; white-space-collapse: preserve;&quot;&gt;Realiza &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;consulta paginable&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;de extractos de la tarjeta de crédito&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font face=&quot;Helvetica&quot;&gt;[MP5S]&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
