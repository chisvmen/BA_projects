        <mxCell id="3Ae5fMcYY-XKI88PPR_W-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;font-size: medium; text-align: start;&quot; data-ccp-timestamp=&quot;1759276992958&quot;&gt;&lt;div data-ccp-timestamp=&quot;1762534912273&quot;&gt;&lt;div data-ccp-timestamp=&quot;1770789353933&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
