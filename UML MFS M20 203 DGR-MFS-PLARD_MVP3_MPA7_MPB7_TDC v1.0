        <mxCell id="dsGI18B7b8BIxwh5u17H-142" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;align=center;fillColor=#bac8d3;strokeColor=#23445d;" value="Escenarios" vertex="1">
