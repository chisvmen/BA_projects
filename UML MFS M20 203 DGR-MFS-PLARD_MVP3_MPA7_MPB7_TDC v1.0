        <mxCell id="CNWZ6g8ySVLg3BFARsDs-1" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeColor=default;" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;b style=&quot;font-size: 12px;&quot;&gt;Funcionalidad:&lt;/b&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ejecutivo Santander a través del Front de Medios de Pagos (FDMP) requiere realizar la &lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;modificación los datos económicos de una tarjeta de credito.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;b style=&quot;font-size: 12px;&quot;&gt;Alcance&lt;/b&gt;: MPV-Full Debit&amp;nbsp;&amp;nbsp;- Realizar la&amp;nbsp;&lt;/span&gt;modificación de los datos económicos de una tarjeta&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&amp;nbsp;de crédito en el canal FDMP.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;b&gt;Reglas de Negocio:&lt;/b&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(22, 22, 22); letter-spacing: 0.16px; background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); letter-spacing: normal;&quot;&gt;El Cliente debe tener una tarjeta de débito (TDD) activa.&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Precondiciones:&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li&gt;&lt;span style=&quot;white-space-collapse: preserve; background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;El Ejecutivo debe tener acceso al canal FDMP y la funcionalidad de Mantenimiento de Tarjetas, opción Limites de tarjeta por moneda, botón &quot;Modificar&quot;.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;El Cliente debe tener una tarjeta de débito (TDD).&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;La tarjeta de débito debe tener establecidos limites de débito globales.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 12px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;b style=&quot;&quot;&gt;Post-Condiciones:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;Los datos económicos de la tarjeta son modificados y actualizados en el sistema.&lt;/span&gt;&lt;/li&gt;&lt;div class=&quot;answer-with-markdown&quot; style=&quot;box-sizing: inherit; padding: 0px; border: 0px; margin: 0px; font-variant-numeric: inherit; font-variant-east-asian: inherit; font-variant-alternates: inherit; font-variant-position: inherit; font-variant-emoji: inherit; font-stretch: inherit; line-height: 1rem; font-optical-sizing: inherit; font-size-adjust: inherit; font-kerning: inherit; font-variation-settings: inherit; font-feature-settings: &amp;quot;liga&amp;quot;; vertical-align: baseline; display: flex; flex-direction: column; gap: 0.5rem; color: rgb(22, 22, 22); letter-spacing: 0.16px;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-style: inherit; font-variant-ligatures: inherit; font-variant-caps: inherit; font-weight: inherit; letter-spacing: 0.16px; background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;El FDMP presenta las modificaciones realizadas a los datos económicos de la tarjeta del Cliente.&lt;/span&gt;&lt;/li&gt;&lt;/div&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="400" width="519" x="4140" y="43" as="geometry" />
        </mxCell>
        <mxCell id="CNWZ6g8ySVLg3BFARsDs-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#bac8d3;strokeColor=#23445d;" value="Funcionalidad" vertex="1">
          <mxGeometry height="40" width="519" x="4140" y="3" as="geometry" />
        </mxCell>
        <mxCell id="CNWZ6g8ySVLg3BFARsDs-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;align=center;fillColor=#bac8d3;strokeColor=#23445d;" value="Escenarios" vertex="1">
          <mxGeometry height="42" width="521" x="4140" y="450" as="geometry" />
        </mxCell>
        <mxCell id="CNWZ6g8ySVLg3BFARsDs-4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=default;" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Escenario 1:&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;span style=&quot;font-weight: bold; font-size: 13px;&quot;&gt;Modificación de datos económicos de la tarjeta&lt;br&gt;&lt;br&gt;&lt;/span&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo modifica datos económicos de la tarjeta del Cliente.&lt;br&gt;&lt;br&gt;Consideraciones:&lt;br&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo accede al canal FDMP.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona la opción &quot;Mantenimiento de Tarjetas&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona la opción &quot;Limites de tarjeta por moneda&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo selecciona el botón &quot;Modificar&quot;.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema consulta los datos económicos de la tarjeta, como los límites diarios y mensuales de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Ejecutivo modifica los datos económicos de la tarjeta.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema actualiza los datos económicos de la tarjeta en el sistema.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; white-space-collapse: preserve;&quot;&gt;&lt;font color=&quot;#242424&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;El Sistema confirma al Ejecutivo que los datos económicos de la tarjeta han sido modificados y actualizados.&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="287" width="521" x="4140" y="493" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
