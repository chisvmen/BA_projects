        <mxCell id="77w-11hD56J_MRPGeAOX-10" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;exitX=0.509;exitY=0.137;exitDx=0;exitDy=0;exitPerimeter=0;" value="">
