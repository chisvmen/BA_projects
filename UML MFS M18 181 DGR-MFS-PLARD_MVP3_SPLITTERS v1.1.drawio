87&quot; data-end=&quot;675&quot; data-col-size=&quot;md&quot;&gt;El archivo se almacena correctamente en el NAS y queda disponible para procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;676&quot; data-end=&quot;853&quot;&gt;&lt;td data-start=&quot;676&quot; data-end=&quot;684&quot; data-col-size=&quot;sm&quot;&gt;CU-02&lt;/td&gt;&lt;td data-start=&quot;684&quot; data-end=&quot;707&quot; data-col-size=&quot;sm&quot;&gt;Recepción de archivo&lt;/td&gt;&lt;td data-start=&quot;707&quot; data-end=&quot;720&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;720&quot; data-end=&quot;784&quot; data-col-size=&quot;md&quot;&gt;Gravity intenta enviar el archivo pero falla la conexión SFTP&lt;/td&gt;&lt;td data-start=&quot;784&quot; data-end=&quot;853&quot; data-col-size=&quot;md&quot;&gt;El sistema registra el error de conexión y genera un log de falla&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;854&quot; data-end=&quot;1002&quot;&gt;&lt;td data-start=&quot;854&quot; data-end=&quot;862&quot; data-col-size=&quot;sm&quot;&gt;CU-03&lt;/td&gt;&lt;td data-start=&quot;862&quot; data-end=&quot;885&quot; data-col-size=&quot;sm&quot;&gt;Detección de archivo&lt;/td&gt;&lt;td data-start=&quot;885&quot; data-end=&quot;895&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;895&quot; data-end=&quot;950&quot; data-col-size=&quot;md&quot;&gt;Control-M detecta la presencia del archivo en el NAS&lt;/td&gt;&lt;td data-start=&quot;950&quot; data-end=&quot;1002&quot; data-col-size=&quot;md&quot;&gt;Se inicia el proceso automático de procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1003&quot; data-end=&quot;1163&quot;&gt;&lt;td data-start=&quot;1003&quot; data-end=&quot;1011&quot; data-col-size=&quot;sm&quot;&gt;CU-04&lt;/td&gt;&lt;td data-start=&quot;1011&quot; data-end=&quot;1034&quot; data-col-size=&quot;sm&quot;&gt;Detección de archivo&lt;/td&gt;&lt;td data-start=&quot;1034&quot; data-end=&quot;1047&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1047&quot; data-end=&quot;1096&quot; data-col-size=&quot;md&quot;&gt;No existe archivo en el directorio configurado&lt;/td&gt;&lt;td data-start=&quot;1096&quot; data-end=&quot;1163&quot; data-col-size=&quot;md&quot;&gt;El proceso finaliza registrando que no hay archivos disponibles&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1164&quot; data-end=&quot;1333&quot;&gt;&lt;td data-start=&quot;1164&quot; data-end=&quot;1172&quot; data-col-size=&quot;sm&quot;&gt;CU-05&lt;/td&gt;&lt;td data-start=&quot;1172&quot; data-end=&quot;1196&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1196&quot; data-end=&quot;1206&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;1206&quot; data-end=&quot;1268&quot; data-col-size=&quot;md&quot;&gt;El archivo cumple con nombre, tamaño y estructura definidos&lt;/td&gt;&lt;td data-start=&quot;1268&quot; data-end=&quot;1333&quot; data-col-size=&quot;md&quot;&gt;El archivo es marcado como válido y continúa el procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1334&quot; data-end=&quot;1479&quot;&gt;&lt;td data-start=&quot;1334&quot; data-end=&quot;1342&quot; data-col-size=&quot;sm&quot;&gt;CU-06&lt;/td&gt;&lt;td data-start=&quot;1342&quot; data-end=&quot;1366&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1366&quot; data-end=&quot;1379&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1379&quot; data-end=&quot;1426&quot; data-col-size=&quot;md&quot;&gt;El archivo no cumple con el formato esperado&lt;/td&gt;&lt;td data-start=&quot;1426&quot; data-end=&quot;1479&quot; data-col-size=&quot;md&quot;&gt;El sistema rechaza el archivo y registra el error&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1480&quot; data-end=&quot;1656&quot;&gt;&lt;td data-start=&quot;1480&quot; data-end=&quot;1488&quot; data-col-size=&quot;sm&quot;&gt;CU-07&lt;/td&gt;&lt;td data-start=&quot;1488&quot; data-end=&quot;1512&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1512&quot; data-end=&quot;1525&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1525&quot; data-end=&quot;1597&quot; data-col-size=&quot;md&quot;&gt;El archivo no corresponde a un tipo configurado en la parametrización&lt;/td&gt;&lt;td data-start=&quot;1597&quot; data-end=&quot;1656&quot; data-col-size=&quot;md&quot;&gt;El sistema registra el error y detiene el procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1657&quot; data-end=&quot;1805&quot;&gt;&lt;td data-start=&quot;1657&quot; data-end=&quot;1665&quot; data-col-size=&quot;sm&quot;&gt;CU-08&lt;/td&gt;&lt;td data-start=&quot;1665&quot; data-end=&quot;1689&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1689&quot; data-end=&quot;1702&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1702&quot; data-end=&quot;1744&quot; data-col-size=&quot;md&quot;&gt;El archivo ya fue procesado previamente&lt;/td&gt;&lt;td data-start=&quot;1744&quot; data-end=&quot;1805&quot; data-col-size=&quot;md&quot;&gt;El sistema detecta archivo duplicado y evita reprocesarlo&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1806&quot; data-end=&quot;1959&quot;&gt;&lt;td data-start=&quot;1806&quot; data-end=&quot;1814&quot; data-col-size=&quot;sm&quot;&gt;CU-09&lt;/td&gt;&lt;td data-start=&quot;1814&quot; data-end=&quot;1843&quot; data-col-size=&quot;sm&quot;&gt;Desencriptación de archivo&lt;/td&gt;&lt;td data-start=&quot;1843&quot; data-end=&quot;1853&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;1853&quot; data-end=&quot;1908&quot; data-col-size=&quot;md&quot;&gt;El archivo llega encriptado y la clave PGP es válida&lt;/td&gt;&lt;td data-start=&quot;1908&quot; data-end=&quot;1959&quot; data-col-size=&quot;md&quot;&gt;El sistema desencripta correctamente el archivo&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1960&quot; data-end=&quot;2138&quot;&gt;&lt;td data-start=&quot;1960&quot; data-end=&quot;1968&quot; data-col-size=&quot;sm&quot;&gt;CU-10&lt;/td&gt;&lt;td data-start=&quot;1968&quot; data-end=&quot;1997&quot; data-col-size=&quot;sm&quot;&gt;Desencriptación de archivo&lt;/td&gt;&lt;td data-start=&quot;1997&quot; data-end=&quot;2010&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;2010&quot; data-end=&quot;2069&quot; data-col-size=&quot;md&quot;&gt;El archivo está encriptado pero la clave PGP es inválida&lt;/td&gt;&lt;td data-start=&quot;2069&quot; data-end=&quot;2138&quot; data-col-size=&quot;md&quot;&gt;El sistema registra error de desencriptación y detiene el proceso&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2139&quot; data-end=&quot;2314&quot;&gt;&lt;td data-start=&quot;2139&quot; data-end=&quot;2147&quot; data-col-size=&quot;sm&quot;&gt;CU-11&lt;/td&gt;&lt;td data-start=&quot;2147&quot; data-end=&quot;2174&quot; data-col-size=&quot;sm&quot;&gt;Procesamiento de archivo&lt;/td&gt;&lt;td data-start=&quot;2174&quot; data-end=&quot;2184&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;2184&quot; data-end=&quot;2256&quot; data-col-size=&quot;md&quot;&gt;El sistema procesa un archivo de flujo Incoming, Migración o Embosado&lt;/td&gt;&lt;td data-start=&quot;2256&quot; data-end=&quot;2314&quot; data-col-size=&quot;md&quot;&gt;El archivo es preparado para transferencia hacia PLARD&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2315&quot; data-end=&quot;2471&quot;&gt;&lt;td data-start=&quot;2315&quot; data-end=&quot;2323&quot; data-col-size=&quot;sm&quot;&gt;CU-12&lt;/td&gt;&lt;td data-start=&quot;2323&quot; data-end=&quot;2350&quot; data-col-size=&quot;sm&quot;&gt;Procesamiento de archivo&lt;/td&gt;&lt;td data-start=&quot;2350&quot; data-end=&quot;2363&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;2363&quot; data-end=&quot;2406&quot; data-col-size=&quot;md&quot;&gt;El archivo contiene datos inconsistentes&lt;/td&gt;&lt;td data-start=&quot;2406&quot; data-end=&quot;2471&quot; data-col-size=&quot;md&quot;&gt;El sistema registra el error y marca el archivo como inválido&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2472&quot; data-end=&quot;2611&quot;&gt;&lt;td data-start=&quot;2472&quot; data-end=&quot;2480&quot; data-col-size=&quot;sm&quot;&gt;CU-13&lt;/td&gt;&lt;td data-start=&quot;2480&quot; data-end=&quot;2504&quot; data-col-size=&quot;sm&quot;&gt;Transferencia a PLARD&lt;/td&gt;&lt;td data-start=&quot;2504&quot; data-end=&quot;2514&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;2514&quot; data-end=&quot;2570&quot; data-col-size=&quot;md&quot;&gt;El sistema envía el archivo hacia la plataforma PLARD&lt;/td&gt;&lt;td data-start=&quot;2570&quot; data-end=&quot;2611&quot; data-col-size=&quot;md&quot;&gt;PLARD recibe el archivo correctamente&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2612&quot; data-end=&quot;2761&quot;&gt;&lt;td data-start=&quot;2612&quot; data-end=&quot;2620&quot; data-col-size=&quot;sm&quot;&gt;CU-14&lt;/td&gt;&lt;td data-start=&quot;2620&quot; data-end=&quot;2644&quot; data-col-size=&quot;sm&quot;&gt;Transferencia a PLARD&lt;/td&gt;&lt;td data-start=&quot;2644&quot; data-end=&quot;2657&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;2657&quot; data-end=&quot;2687&quot; data-col-size=&quot;md&quot;&gt;Falla la conexión con PLARD&lt;/td&gt;&lt;td data-start=&quot;2687&quot; data-end=&quot;2761&quot; data-col-size=&quot;md&quot;&gt;El sistema registra el error y ejecuta política de reintento si aplica&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2762&quot; data-end=&quot;2916&quot;&gt;&lt;td data-start=&quot;2762&quot; data-end=&quot;2770&quot; data-col-size=&quot;sm&quot;&gt;CU-15&lt;/td&gt;&lt;td data-start=&quot;2770&quot; data-end=&quot;2793&quot; data-col-size=&quot;sm&quot;&gt;Almacenamiento en S3&lt;/td&gt;&lt;td data-start=&quot;2793&quot; data-end=&quot;2803&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;2803&quot; data-end=&quot;2864&quot; data-col-size=&quot;md&quot;&gt;PLARD recibe el archivo y lo almacena en el repositorio S3&lt;/td&gt;&lt;td data-start=&quot;2864&quot; data-end=&quot;2916&quot; data-col-size=&quot;md&quot;&gt;El archivo queda disponible en el repositorio S3&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2917&quot; data-end=&quot;3054&quot;&gt;&lt;td data-start=&quot;2917&quot; data-end=&quot;2925&quot; data-col-size=&quot;sm&quot;&gt;CU-16&lt;/td&gt;&lt;td data-start=&quot;2925&quot; data-end=&quot;2948&quot; data-col-size=&quot;sm&quot;&gt;Almacenamiento en S3&lt;/td&gt;&lt;td data-start=&quot;2948&quot; data-end=&quot;2961&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;2961&quot; data-end=&quot;3006&quot; data-col-size=&quot;md&quot;&gt;Error en el almacenamiento en el bucket S3&lt;/td&gt;&lt;td data-start=&quot;3006&quot; data-end=&quot;3054&quot; data-col-size=&quot;md&quot;&gt;El sistema registra el error y genera alerta&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;3055&quot; data-end=&quot;3207&quot;&gt;&lt;td data-start=&quot;3055&quot; data-end=&quot;3063&quot; data-col-size=&quot;sm&quot;&gt;CU-17&lt;/td&gt;&lt;td data-start=&quot;3063&quot; data-end=&quot;3090&quot; data-col-size=&quot;sm&quot;&gt;Registro de trazabilidad&lt;/td&gt;&lt;td data-start=&quot;3090&quot; data-end=&quot;3100&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;3100&quot; data-end=&quot;3151&quot; data-col-size=&quot;md&quot;&gt;El sistema registra cada etapa del procesamiento&lt;/td&gt;&lt;td data-start=&quot;3151&quot; data-end=&quot;3207&quot; data-col-size=&quot;md&quot;&gt;Se genera log completo del ciclo de vida del archivo&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;3208&quot; data-end=&quot;3333&quot;&gt;&lt;td data-start=&quot;3208&quot; data-end=&quot;3216&quot; data-col-size=&quot;sm&quot;&gt;CU-18&lt;/td&gt;&lt;td data-start=&quot;3216&quot; data-end=&quot;3243&quot; data-col-size=&quot;sm&quot;&gt;Registro de trazabilidad&lt;/td&gt;&lt;td data-start=&quot;3243&quot; data-end=&quot;3256&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;3256&quot; data-end=&quot;3295&quot; data-col-size=&quot;md&quot;&gt;Falla el sistema de logs o monitoreo&lt;/td&gt;&lt;td data-start=&quot;3295&quot; data-end=&quot;3333&quot; data-col-size=&quot;md&quot;&gt;El sistema genera alerta operativa&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;&lt;br&gt;&lt;h1 data-section-id=&quot;1q5sh01&quot; data-start=&quot;3340&quot; data-end=&quot;3369&quot;&gt;&lt;br&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="1000" width="720" x="60" y="169" as="geometry" />
        </mxCell>
        <mxCell id="YQptBG0Ae-qTaepZ0Ma5-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;1cdq8qg&quot; data-start=&quot;291&quot; data-end=&quot;338&quot;&gt;Matriz de Pruebas – Procesamiento de Archivos&lt;/h1&gt;&lt;br&gt;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div tabindex=&quot;-1&quot; class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot;&gt;&lt;table data-start=&quot;340&quot; data-end=&quot;3914&quot; class=&quot;w-fit min-w-(--thread-content-width)&quot;&gt;&lt;thead data-start=&quot;340&quot; data-end=&quot;457&quot;&gt;&lt;tr data-start=&quot;340&quot; data-end=&quot;457&quot;&gt;&lt;th data-start=&quot;340&quot; data-end=&quot;345&quot; data-col-size=&quot;sm&quot; class=&quot;&quot;&gt;ID&lt;/th&gt;&lt;th data-start=&quot;345&quot; data-end=&quot;362&quot; data-col-size=&quot;sm&quot; class=&quot;&quot;&gt;Caso de Prueba&lt;/th&gt;&lt;th data-start=&quot;362&quot; data-end=&quot;374&quot; data-col-size=&quot;sm&quot; class=&quot;&quot;&gt;Escenario&lt;/th&gt;&lt;th data-start=&quot;374&quot; data-end=&quot;391&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Precondiciones&lt;/th&gt;&lt;th data-start=&quot;391&quot; data-end=&quot;417&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Criterios de Aceptación&lt;/th&gt;&lt;th data-start=&quot;417&quot; data-end=&quot;438&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Resultado Esperado&lt;/th&gt;&lt;th data-start=&quot;438&quot; data-end=&quot;457&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Postcondiciones&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-start=&quot;571&quot; data-end=&quot;3914&quot;&gt;&lt;tr data-start=&quot;571&quot; data-end=&quot;805&quot;&gt;&lt;td data-start=&quot;571&quot; data-end=&quot;579&quot; data-col-size=&quot;sm&quot;&gt;TC-01&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;579&quot; data-end=&quot;602&quot;&gt;Recepción de archivo&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;602&quot; data-end=&quot;612&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;612&quot; data-end=&quot;659&quot;&gt;Conectividad SFTP activa entre Gravity y NAS&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;659&quot; data-end=&quot;720&quot;&gt;El sistema debe recibir el archivo correctamente en el NAS&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;720&quot; data-end=&quot;755&quot;&gt;El archivo se almacena en el NAS&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;755&quot; data-end=&quot;805&quot;&gt;El archivo queda disponible para procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;806&quot; data-end=&quot;994&quot;&gt;&lt;td data-start=&quot;806&quot; data-end=&quot;814&quot; data-col-size=&quot;sm&quot;&gt;TC-02&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;814&quot; data-end=&quot;837&quot;&gt;Recepción de archivo&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;837&quot; data-end=&quot;850&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;850&quot; data-end=&quot;883&quot;&gt;Conectividad SFTP interrumpida&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;883&quot; data-end=&quot;929&quot;&gt;El sistema debe registrar error de conexión&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;929&quot; data-end=&quot;955&quot;&gt;El archivo no se recibe&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;955&quot; data-end=&quot;994&quot;&gt;Se genera registro de error en logs&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;995&quot; data-end=&quot;1201&quot;&gt;&lt;td data-start=&quot;995&quot; data-end=&quot;1003&quot; data-col-size=&quot;sm&quot;&gt;TC-03&lt;/td&gt;&lt;td data-start=&quot;1003&quot; data-end=&quot;1026&quot; data-col-size=&quot;sm&quot;&gt;Detección de archivo&lt;/td&gt;&lt;td data-start=&quot;1026&quot; data-end=&quot;1036&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;1036&quot; data-end=&quot;1064&quot; data-col-size=&quot;md&quot;&gt;Archivo disponible en NAS&lt;/td&gt;&lt;td data-start=&quot;1064&quot; data-end=&quot;1123&quot; data-col-size=&quot;md&quot;&gt;Control-M debe detectar el archivo y ejecutar el proceso&lt;/td&gt;&lt;td data-start=&quot;1123&quot; data-end=&quot;1160&quot; data-col-size=&quot;md&quot;&gt;El proceso de procesamiento inicia&lt;/td&gt;&lt;td data-start=&quot;1160&quot; data-end=&quot;1201&quot; data-col-size=&quot;md&quot;&gt;El archivo pasa a etapa de validación&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1202&quot; data-end=&quot;1407&quot;&gt;&lt;td data-start=&quot;1202&quot; data-end=&quot;1210&quot; data-col-size=&quot;sm&quot;&gt;TC-04&lt;/td&gt;&lt;td data-start=&quot;1210&quot; data-end=&quot;1233&quot; data-col-size=&quot;sm&quot;&gt;Detección de archivo&lt;/td&gt;&lt;td data-start=&quot;1233&quot; data-end=&quot;1246&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1246&quot; data-end=&quot;1280&quot; data-col-size=&quot;md&quot;&gt;No existe archivo en directorio&lt;/td&gt;&lt;td data-start=&quot;1280&quot; data-end=&quot;1328&quot; data-col-size=&quot;md&quot;&gt;El sistema debe registrar ausencia de archivo&lt;/td&gt;&lt;td data-start=&quot;1328&quot; data-end=&quot;1364&quot; data-col-size=&quot;md&quot;&gt;El proceso finaliza sin ejecución&lt;/td&gt;&lt;td data-start=&quot;1364&quot; data-end=&quot;1407&quot; data-col-size=&quot;md&quot;&gt;Registro en logs de archivo inexistente&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1408&quot; data-end=&quot;1616&quot;&gt;&lt;td data-start=&quot;1408&quot; data-end=&quot;1416&quot; data-col-size=&quot;sm&quot;&gt;TC-05&lt;/td&gt;&lt;td data-start=&quot;1416&quot; data-end=&quot;1440&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1440&quot; data-end=&quot;1450&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;1450&quot; data-end=&quot;1478&quot; data-col-size=&quot;md&quot;&gt;Archivo disponible en NAS&lt;/td&gt;&lt;td data-start=&quot;1478&quot; data-end=&quot;1545&quot; data-col-size=&quot;md&quot;&gt;El archivo debe cumplir con nombre, tamaño y formato configurado&lt;/td&gt;&lt;td data-start=&quot;1545&quot; data-end=&quot;1581&quot; data-col-size=&quot;md&quot;&gt;El archivo es marcado como válido&lt;/td&gt;&lt;td data-start=&quot;1581&quot; data-end=&quot;1616&quot; data-col-size=&quot;md&quot;&gt;El archivo pasa a procesamiento&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1617&quot; data-end=&quot;1800&quot;&gt;&lt;td data-start=&quot;1617&quot; data-end=&quot;1625&quot; data-col-size=&quot;sm&quot;&gt;TC-06&lt;/td&gt;&lt;td data-start=&quot;1625&quot; data-end=&quot;1649&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo&lt;/td&gt;&lt;td data-start=&quot;1649&quot; data-end=&quot;1662&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1662&quot; data-end=&quot;1695&quot; data-col-size=&quot;md&quot;&gt;Archivo con formato incorrecto&lt;/td&gt;&lt;td data-start=&quot;1695&quot; data-end=&quot;1733&quot; data-col-size=&quot;md&quot;&gt;El sistema debe rechazar el archivo&lt;/td&gt;&lt;td data-start=&quot;1733&quot; data-end=&quot;1771&quot; data-col-size=&quot;md&quot;&gt;El archivo es marcado como inválido&lt;/td&gt;&lt;td data-start=&quot;1771&quot; data-end=&quot;1800&quot; data-col-size=&quot;md&quot;&gt;Registro de error en logs&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1801&quot; data-end=&quot;2002&quot;&gt;&lt;td data-start=&quot;1801&quot; data-end=&quot;1809&quot; data-col-size=&quot;sm&quot;&gt;TC-07&lt;/td&gt;&lt;td data-start=&quot;1809&quot; data-end=&quot;1843&quot; data-col-size=&quot;sm&quot;&gt;Validación de archivo duplicado&lt;/td&gt;&lt;td data-start=&quot;1843&quot; data-end=&quot;1856&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&gt;&lt;td data-start=&quot;1856&quot; data-end=&quot;1888&quot; data-col-size=&quot;md&quot;&gt;Archivo previamente procesado&lt;/td&gt;&lt;td data-start=&quot;1888&quot; data-end=&quot;1929&quot; data-col-size=&quot;md&quot;&gt;El sistema debe identificar duplicados&lt;/td&gt;&lt;td data-start=&quot;1929&quot; data-end=&quot;1969&quot; data-col-size=&quot;md&quot;&gt;El archivo no es procesado nuevamente&lt;/td&gt;&lt;td data-start=&quot;1969&quot; data-end=&quot;2002&quot; data-col-size=&quot;md&quot;&gt;Registro de archivo duplicado&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2003&quot; data-end=&quot;2247&quot;&gt;&lt;td data-start=&quot;2003&quot; data-end=&quot;2011&quot; data-col-size=&quot;sm&quot;&gt;TC-08&lt;/td&gt;&lt;td data-start=&quot;2011&quot; data-end=&quot;2040&quot; data-col-size=&quot;sm&quot;&gt;Desencriptación de archivo&lt;/td&gt;&lt;td data-start=&quot;2040&quot; data-end=&quot;2050&quot; data-col-size=&quot;sm&quot;&gt;Exitoso&lt;/td&gt;&lt;td data-start=&quot;2050&quot; data-end=&quot;2092&quot; data-col-size=&quot;md&quot;&gt;Archivo encriptado con clave PGP válida&lt;/td&gt;&lt;td data-start=&quot;2092&quot; data-end=&quot;2148&quot; data-col-size=&quot;md&quot;&gt;El sistema debe desencriptar correctamente el archivo&lt;/td&gt;&lt;td data-start=&quot;2148&quot; data-end=&quot;2197&quot; data-col-size=&quot;md&quot;&gt;El archivo queda disponible para procesamiento&lt;/td&gt;&lt;td data-start=&quot;2197&quot; data-end=&quot;2247&quot; data-col-size=&quot;md&quot;&gt;Archivo desencriptado almacenado temporalmente&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;2248&quot; data-end=&quot;2447&quot;&gt;&lt;td data-start=&quot;2248&quot; data-end=&quot;2256&quot; data-col-size=&quot;sm&quot;&gt;TC-09&lt;/td&gt;&lt;td data-start=&quot;2256&quot; data-end=&quot;2285&quot; data-col-size=&quot;sm&quot;&gt;Desencriptación de archivo&lt;/td&gt;&lt;td data-start=&quot;2285&quot; data-end=&quot;2298&quot; data-col-size=&quot;sm&quot;&gt;No exitoso&lt;/td&g