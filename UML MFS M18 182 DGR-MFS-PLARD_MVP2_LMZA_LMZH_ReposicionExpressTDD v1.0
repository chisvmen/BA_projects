%3BDetalle%26quot%3B%20para%20consultar%20el%20detalle%20del%20movimiento%20seleccionado.%20Se%20desplegar%C3%A1%20el%20detalle%20del%20movimiento%20seleccionado%20y%20se%20deber%C3%A1%20seleccionar%20la%20opci%C3%B3n%20%26quot%3BConciliaciones%26quot%3B%20y%20se%20deber%C3%A1%20ejecutara%20ejecutar%20la%20transacci%C3%B3n%20LMZH%20al%20seleccionar%20el%20combobox%20del%20Indicador%20de%20Ajuste%20para%20determinar%20si%20es%20Cargo%20o%20Abono%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BNavegaci%C3%B3n%3A%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bmen%C3%BA%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BMovimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Detalle%20de%20Movimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Conciliaciones%26amp%3Bnbsp%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bdiv%26gt%3B%2