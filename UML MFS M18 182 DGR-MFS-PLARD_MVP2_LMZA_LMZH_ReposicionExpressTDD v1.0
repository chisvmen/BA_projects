        <mxCell id="MYeToY-9Kgh44GqMJ70t-89" parent="MYeToY-9Kgh44GqMJ70t-79" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;recursiveResize=0;container=1;collapsible=0;width=50;height=15;" value="ref" vertex="1">
