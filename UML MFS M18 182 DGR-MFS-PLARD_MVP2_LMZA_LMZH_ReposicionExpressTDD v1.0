        <mxCell id="pMTrQlvDd1zJoh9T163s-34" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;strokeWidth=1;strokeColor=default;" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;strong data-start=&quot;201&quot; data-end=&quot;246&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font&gt;Escenario 2:&amp;nbsp;&lt;/font&gt;&lt;/strong&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 13px;&quot;&gt;Reposición de Tarjeta Express Onboarding Digital&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;El Ejecutivo Santander&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;ingresa al portal Terminal Financiero y&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;solicita la Reposición&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Express de&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tarjeta de Débito.&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;El criterio de reposición es por PAN, se muestra la información:&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Se debe informar el PAN anterior, el PAN de la nueva tarjeta y el CANAL solicitante.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;El criterio de reposición es por CUENTA DE CHEQUES:&amp;nbsp;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Se debe informar el Número de cliente, Cuenta de cheques, PAN de la nueva tarjeta y el CANAL solicitante.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;La plataforma PLARD con ayuda de la capa de integración procesan la solicitud y envían&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;al canal la información necesaria para realizar la reposición de una tarjeta express TDD.&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Consideraciones:&lt;/b&gt;&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;El cliente Santander deberá acudir a la sucursal bancaria física.&lt;/li&gt;&lt;li&gt;El ejecutivo Santander deberá tener acceso al sistema Terminal Financiero de Sucursales.&lt;/li&gt;&lt;li&gt;El cliente Santander deberá presentar una identificación con fotografía oficial&lt;/li&gt;&lt;li&gt;El cliente Santander deberá presentar&amp;nbsp;el número de la tarjeta de débito anterior.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;p data-start=&quot;248&quot; data-end=&quot;310&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgba(0, 0, 0, 0), rgba(237, 237, 237, 0)); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3raphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20parent%3D%221%22%20style%3D%22text%3Bhtml%3D1%3Balign%3Dleft%3BverticalAlign%3Dtop%3BwhiteSpace%3Dwrap%3Brounded%3D0%3BfontSize%3D12%3BstrokeWidth%3D1%3BstrokeColor%3Ddefault%3B%22%20value%3D%22%26lt%3Bdiv%20style%3D%26quot%3B%26quot%3B%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bstrong%20data-start%3D%26quot%3B201%26quot%3B%20data-end%3D%26quot%3B246%26quot%3B%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26lt%3Bfont%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Ffont%26gt%3B%26lt%3B%2Fstrong%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bstrong%20data-start%3D%26quot%3B201%26quot%3B%20data-end%3D%26quot%3B246%26quot%3B%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26lt%3Bfont%26gt%3BEscenario%201%3A%26amp%3Bnbsp%3B%26lt%3B%2Ffont%26gt%3B%26lt%3B%2Fstrong%26gt%3B%26lt%3Bb%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%20font-size%3A%2013px%3B%26quot%3B%26gt%3BConsulta%20de%20Conciliaci%C3%B3n%20por%20PAN%26lt%3B%2Fb%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%20style%3D%26quot%3B%26quot%3B%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bfont%26gt%3BEsta%20transacci%C3%B3n%20se%20ejecuta%20a%20traves%20del%20canal%20del%20FMDP.%26amp%3Bnbsp%3B%26lt%3B%2Ffont%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BEl%20Ejecutivo%20Santander%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bingresa%20a%20la%20pantalla%20web%20del%20canal%2C%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%26amp%3Bnbsp%3Bel%20men%C3%BA%20con%20la%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26amp%3Bnbsp%3Bopci%C3%B3n%20%26quot%3BMovimientos%20de%20D%C3%A9bito%26quot%3B%2C%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%20el%20criterio%20de%20busqueda%20por%20PAN%20numero%20de%20la%20tarjeta%20de%20debito%2C%20se%20puede%20acotar%20de%20manera%20opcional%20el%20periodo%20de%20b%C3%BAsqueda%20de%20movimientos%20seleccionando%20fecha%20de%20inicio%20y%20fecha%20de%20fin%20del%20periodo%20de%20movimientos%20a%20consultar.%20Una%20vez%20realizada%20la%20b%C3%BAsqueda%20(trx%20MP6K)%2C%20se%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%20el%20movimiento%20deseado%20y%20se%20selecciona%20el%20bot%C3%B3n%20%26quot%3BDetalle%26quot%3B%20para%20consultar%20el%20detalle%20del%20movimiento%20seleccionado.%20Se%20desplegar%C3%A1%20el%20detalle%20del%20movimiento%20seleccionado%20y%20se%20deber%C3%A1%20seleccionar%20la%20opci%C3%B3n%20%26quot%3BConciliaciones%26quot%3B%20y%20se%20deber%C3%A1%20ejecutara%20ejecutar%20la%20transacci%C3%B3n%20LMZH%20al%20seleccionar%20el%20combobox%20del%20Indicador%20de%20Ajuste%20para%20determinar%20si%20es%20Cargo%20o%20Abono%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BNavegaci%C3%B3n%3A%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bmen%C3%BA%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BMovimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Detalle%20de%20Movimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Conciliaciones%26amp%3Bnbsp%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20vertex%3D%221%22%3E%3CmxGeometry%20height%3D%22228%22%20width%3D%22769%22%20x%3D%22832%22%20y%3D%22-648%