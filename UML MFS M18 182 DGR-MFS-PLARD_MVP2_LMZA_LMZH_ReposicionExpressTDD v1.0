t%3B%2Ffont%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BEl%20Ejecutivo%20Santander%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bingresa%20a%20la%20pantalla%20web%20del%20canal%2C%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%26amp%3Bnbsp%3Bel%20men%C3%BA%20con%20la%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26amp%3Bnbsp%3Bopci%C3%B3n%20%26quot%3BMovimientos%20de%20D%C3%A9bito%26quot%3B%2C%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%20el%20criterio%20de%20busqueda%20por%20PAN%20numero%20de%20la%20tarjeta%20de%20debito%2C%20se%20puede%20acotar%20de%20manera%20opcional%20el%20periodo%20de%20b%C3%BAsqueda%20de%20movimientos%20seleccionando%20fecha%20de%20inicio%20y%20fecha%20de%20fin%20del%20periodo%20de%20movimientos%20a%20consultar.%20Una%20vez%20realizada%20la%20b%C3%BAsqueda%20(trx%20MP6K)%2C%20se%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bselecciona%20el%20movimiento%20deseado%20y%20se%20selecciona%20el%20bot%C3%B3n%20%26quot%3BDetalle%26quot%3B%20para%20consultar%20el%20detalle%20del%20movimiento%20seleccionado.%20Se%20desplegar%C3%A1%20el%20detalle%20del%20movimiento%20seleccionado%20y%20se%20deber%C3%A1%20seleccionar%20la%20opci%C3%B3n%20%26quot%3BConciliaciones%26quot%3B%20y%20se%20deber%C3%A1%20ejecutara%20ejecutar%20la%20transacci%C3%B3n%20LMZH%20al%20seleccionar%20el%20combobox%20del%20Indicador%20de%20Ajuste%20para%20determinar%20si%20es%20Cargo%20o%20Abono%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3Bp%20data-start%3D%26quot%3B248%26quot%3B%20data-end%3D%26quot%3B310%26quot%3B%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BNavegaci%C3%B3n%3A%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3Bmen%C3%BA%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3BMovimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Detalle%20de%20Movimientos%20de%20D%C3%A9bito%20%26amp%3Bgt%3B%26amp%3Bgt%3B%20Conciliaciones%26amp%3Bnbsp%3B%26amp%3Bnbsp%3B%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fp%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20vertex%3D%221%22%3E%3CmxGeometry%20height%3D%22228%22%20width%3D%22769%22%20x%3D%22832%22%20y%3D%22-648%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/h3&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
